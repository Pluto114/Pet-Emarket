AMAP_API_KEY=your-amap-web-service-key
AI_SERVICE_ENABLED=false
AI_SERVICE_BASE_URL=http://localhost:8001
AI_SERVICE_TIMEOUT_SECONDS=10

MAIL_ENABLED=false
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-smtp-account@example.com
SMTP_PASSWORD=your-qq-mail-smtp-authorization-code
MAIL_FROM=your-smtp-account@example.com
SMTP_SSL_ENABLED=true
SMTP_STARTTLS_ENABLED=false
MAIL_DEV_CODE_IN_RESPONSE=false
